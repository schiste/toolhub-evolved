{
	"name": "toolhub-evolved",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . --max-warnings 0",
		"lint:css": "stylelint \"public_html/styles/**/*.css\"",
		"spell": "cspell --no-progress \"public_html/**/*.{js,mjs,css,html}\" \"tools/**/*.mjs\" \"*.md\" \"docs/**/*.md\" \"proxy/**/*.py\"",
		"types": "tsc -p jsconfig.json",
		"dead:check": "knip --production",
		"dup:check": "jscpd --config .jscpd.json",
		"checks": "node tools/checks.mjs",
		"budget": "node tools/js-budget.mjs",
		"test:unit": "vitest run",
		"coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"mutation": "stryker run",
		"commitlint": "commitlint --from origin/main --to HEAD",
		"secrets": "gitleaks dir . -c .gitleaks.toml --redact --no-banner",
		"audit:js": "npm audit --audit-level=moderate",
		"hooks:install": "tools/install-hooks.sh"
	},
	"lint-staged": {
		"*.{js,mjs}": [
			"eslint --fix --max-warnings 0",
			"prettier --write"
		],
		"*.css": [
			"stylelint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml,html,svg}": "prettier --write"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.12.1",
		"@commitlint/cli": "21.1.0",
		"@commitlint/config-conventional": "21.1.0",
		"@eslint/js": "10.0.1",
		"@playwright/test": "1.61.1",
		"@stryker-mutator/core": "9.6.1",
		"@stryker-mutator/vitest-runner": "9.6.1",
		"@vitest/coverage-v8": "4.1.9",
		"cspell": "10.0.1",
		"eslint": "10.5.0",
		"eslint-plugin-headers": "1.3.4",
		"eslint-plugin-import-x": "4.17.0",
		"eslint-plugin-sonarjs": "4.1.0",
		"eslint-plugin-unicorn": "69.0.0",
		"espree": "11.2.0",
		"globals": "16.5.0",
		"happy-dom": "20.10.6",
		"jscpd": "5.0.11",
		"knip": "5.88.1",
		"lint-staged": "17.0.8",
		"prettier": "3.8.4",
		"stylelint": "16.26.1",
		"stylelint-config-standard": "39.0.1",
		"stylelint-declaration-strict-value": "1.11.1",
		"ts-api-utils": "2.5.0",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	}
}
